RewriteEngine On
# Uudelleenohjataan /haku-yritys -> /index.html?haku=yritys
RewriteRule ^haku-(.*)$ /index.html?haku=$1 [L,QSA]

# Uudelleenohjataan /asia-kategoria/asia -> /asiahaku.html?cat=kategoria&issue=asia
RewriteRule ^(?:asia|asiahaku)-([^/]+)/(.*)$ /asiahaku.html?cat=$1&issue=$2 [L,QSA]

# Aluesivut ja niiden kategoriat/tägit
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)$ /alue.html?area=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/([a-z0-9-]+)$ /alue.html?area=$1&cat=$2 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/([a-z0-9-]+)/([a-z0-9-]+)$ /alue.html?area=$1&cat=$2&tag=$3 [L,QSA]
