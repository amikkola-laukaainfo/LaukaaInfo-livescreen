{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "LaukaaInfo Ratkaisulähtöinen profilointi v5",
    "description": "Schema yritysprofiileille. Sisältää intent-pohjaisen pisteytyksen ja kontekstuaaliset suositukset.",
    "type": "object",
    "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "core": {
            "type": "object",
            "properties": {
                "fits_for": {
                    "type": "object",
                    "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 100 },
                    "description": "Sopivuus pääpolkuihin (esim. events-and-celebrations)"
                },
                "intent_codes": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "v5 Taksonomian mukaiset koodit"
                },
                "intent_scores": {
                    "type": "object",
                    "additionalProperties": { "type": "integer" }
                },
                "priority_score": { "type": "integer" },
                "service_area": {
                    "type": "object",
                    "properties": {
                        "mode": { "type": "string", "enum": ["TOIMIPISTE", "SERVICE_AREA", "ETAPALVELU", "VALTAKUNNALLINEN"] },
                        "radius_km": { "type": "integer" },
                        "regions": { "type": "array", "items": { "type": "string" } },
                        "note": { "type": "string" }
                    }
                },
                "emergency_available": { "type": "boolean" },
                "contract_customer_available": { "type": "boolean" },
                "corporate_clients": { "type": "boolean" },
                "home_service": { "type": "boolean" },
                "weekend_service": { "type": "boolean" },
                "not_suitable_for": { "type": "array", "items": { "type": "string" } },
                "paired_with_by_context": {
                    "type": "object",
                    "additionalProperties": { "type": "array", "items": { "type": "string" } },
                    "description": "Kontekstuaaliset suositukset (esim. general, events-and-celebrations)"
                },
                "sub_contexts": {
                    "oneOf": [
                        { "type": "array", "items": { "type": "string" } },
                        { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } }
                    ]
                },
                "node_links": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["fits_for", "intent_codes", "intent_scores", "priority_score", "service_area"]
        },
        "categories": {
            "type": "object",
            "properties": {
                "core": {
                    "type": "object",
                    "properties": {
                        "description": { "type": "string" },
                        "website": { "type": "string" },
                        "email": { "type": "string" },
                        "phone": { "type": "string" }
                    }
                },
                "events_and_celebrations": { "type": "object" },
                "business_events": { "type": "object" },
                "funerals_and_memorials": { "type": "object" },
                "moving_and_housing": { "type": "object" },
                "construction_and_maintenance": { "type": "object" },
                "cottage_services": { "type": "object" },
                "housing_company_and_contracts": { "type": "object" },
                "startup_services": { "type": "object" },
                "business_growth": { "type": "object" },
                "wellbeing_and_beauty": { "type": "object" },
                "animals": { "type": "object" },
                "family_and_children": { "type": "object" },
                "auto_services": { "type": "object" }
            }
        },
        "meta": {
            "type": "object",
            "properties": {
                "last_updated": { "type": "string" },
                "verified_by": { "type": "string" },
                "status": { "type": "string", "enum": ["draft", "verified", "pending_review"] }
            }
        }
    },
    "required": ["id", "name", "core", "categories", "meta"]
}
